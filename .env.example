# App
PORT=3000
NODE_ENV=development
JWT_SECRET=your_secure_jwt_secret_at_least_10_chars

# Database (PostgreSQL)
# Use this for local development without Docker
DATABASE_URL="postgresql://user:password@localhost:5432/medium_clone?schema=public"

# Use this for Docker setup (matches docker-compose.yml)
# DATABASE_URL="postgresql://medium_user:medium_password@db:5432/medium_db?schema=public"

# Redis
REDIS_URL=redis://localhost:6379
# For Docker:
# REDIS_URL=redis://redis:6379
