generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) 
  email        String   @unique              
  username     String   @unique              
  passwordHash String                        
  bio          String?                       
  image        String?                       
  
  createdAt    DateTime @default(now())      
  updatedAt    DateTime @updatedAt           
}